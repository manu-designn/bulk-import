<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="bulk-import-architecture">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Bulk Data Import &amp; Validation System — Architecture" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="10" width="560" height="30" as="geometry" />
        </mxCell>

        <!-- Client -->
        <mxCell id="client" value="Client&#10;(Postman / Swagger UI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Controller -->
        <mxCell id="controller" value="ImportController&#10;(REST API layer, /api/v1/imports)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="460" y="150" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- Service -->
        <mxCell id="service" value="ImportJobServiceImpl&#10;submitImport / getJob / getAllJobs / getRecords / getSummary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="440" y="260" width="320" height="70" as="geometry" />
        </mxCell>

        <!-- FileStorageService -->
        <mxCell id="fileStorage" value="FileStorageService&#10;stream upload to disk + SHA-256 hash&#10;(single I/O pass)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="260" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- ImportJobRepository -->
        <mxCell id="jobRepo" value="ImportJobRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1140" y="270" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- AsyncConfig -->
        <mxCell id="asyncExecutor" value="AsyncConfig&#10;importTaskExecutor&#10;(4-8 threads, CallerRunsPolicy backpressure)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- AsyncImportProcessor -->
        <mxCell id="asyncProcessor" value="AsyncImportProcessor&#10;@Async processFileAsync(jobId)&#10;(runs on background thread)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="440" y="380" width="320" height="70" as="geometry" />
        </mxCell>

        <!-- StaleJobRecoveryScheduler -->
        <mxCell id="scheduler" value="StaleJobRecoveryScheduler&#10;@Scheduled every 5 min&#10;marks stuck PROCESSING jobs FAILED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="380" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- RowParserFactory -->
        <mxCell id="parserFactory" value="RowParserFactory&#10;(picks parser by file extension)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="440" y="500" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- Parsers -->
        <mxCell id="csvParser" value="CsvRowParser&#10;streaming Reader&#10;(Commons CSV)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="610" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="xlsxParser" value="XlsxRowParser&#10;streaming SAX + bounded queue&#10;(POI event API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="610" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="xlsParser" value="XlsRowParser&#10;HSSF, non-streaming&#10;(documented limitation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="610" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- RowValidator -->
        <mxCell id="rowValidator" value="RowValidator&#10;Jakarta Bean Validation&#10;(PersonImportRow: @NotBlank, @Email, @Min/@Max)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="710" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- Dedup hashing -->
        <mxCell id="dedup" value="HashUtil.hashRow()&#10;in-memory Set&lt;String&gt;&#10;within-file duplicate detection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="710" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Batch buffer -->
        <mxCell id="batchBuffer" value="Batch buffer (List&lt;ImportRecord&gt;)&#10;flush every recordBatchSize rows (default 500)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="800" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- ImportRecordRepository -->
        <mxCell id="recordRepo" value="ImportRecordRepository&#10;saveAll(buffer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="480" y="890" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Database -->
        <mxCell id="db" value="Database (Flyway-managed)&#10;MySQL&#10;import_job, import_record" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;shape=cylinder3;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="970" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="client" target="controller">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="delegates" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="controller" target="service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="store(file, jobId)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="service" target="fileStorage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="findByFileHash / save(PENDING)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="service" target="jobRepo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="processFileAsync(jobId) — returns immediately" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;dashed=1;strokeColor=#d79b00;" edge="1" parent="1" source="service" target="asyncProcessor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="runs on" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="asyncExecutor" target="asyncProcessor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="forFile(fileName)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="asyncProcessor" target="parserFactory">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="parserFactory" target="csvParser">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="parserFactory" target="xlsxParser">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="parserFactory" target="xlsParser">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" value="per row" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="asyncProcessor" target="rowValidator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="hashRow(row)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="asyncProcessor" target="dedup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="rowValidator" target="batchBuffer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" value="saveAll() every N rows" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="batchBuffer" target="recordRepo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="recordRepo" target="db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="jobRepo" target="db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e17" value="find stale PROCESSING jobs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="scheduler" target="jobRepo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e18" value="read path (getJob / getAllJobs / getRecords / getSummary)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="service" target="recordRepo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
